PORT=5001
NODE_ENV=development
CLIENT_URL=http://localhost:5173
CLIENT_URL_2=http://localhost:5174
BACKEND_URL=it is also needed for image handling

# Prisma
DATABASE_URL="prisma+postgres://localhost:51213/?api_"

# Auth
JWT_SECRET=your_super_secret_jwt_key
JWT_EXPIRE=7d

# Razorpay (Test Credentials)
RAZORPAY_KEY_ID=rzp_test_your_key_id
RAZORPAY_KEY_SECRET=your_key_secret

# Email (SMTP)
SMTP_HOST=smtp.mailtrap.io
SMTP_PORT=2525
SMTP_USER=your_mailtrap_user
SMTP_PASS=your_mailtrap_pass
SMTP_FROM_EMAIL=noreply@gms.com
SMTP_FROM_NAME="GMS Support"

# Storage
# Options: local, s3
STORAGE_PROVIDER=local
S3_BUCKET_NAME=gms-uploads
S3_REGION=us-east-1
AWS_ACCESS_KEY_ID=your_access_key
AWS_SECRET_ACCESS_KEY=your_secret_key
UPLOAD_DIR=uploads