generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model SuperAdmin {
  id                     String         @id @default(cuid())
  name                   String
  email                  String         @unique
  password               String
  role                   SuperAdminRole @default(SUPPORT_MANAGER)
  canManageTenants       Boolean        @default(false)
  canManageSubs          Boolean        @default(false)
  canManageBanners       Boolean        @default(false)
  canManageAnnouncements Boolean        @default(false)
  canManageSupport       Boolean        @default(false)
  canManageCms           Boolean        @default(false)
  phone                  String?
  avatar                 String?
  isActive               Boolean        @default(true)
  lastLoginAt            DateTime?
  createdAt              DateTime       @default(now())
  updatedAt              DateTime       @updatedAt
  verifiedTenants        Tenant[]       @relation("VerifiedBy")

  @@map("super_admins")
}

model SubscriptionPlan {
  id                 String               @id @default(cuid())
  name               String
  type               PlanType             @unique
  monthlyPrice       Decimal              @db.Decimal(10, 2)
  yearlyPrice        Decimal              @db.Decimal(10, 2)
  maxStaffUsers      Int
  maxVehicles        Int
  maxJobCards        Int?
  hasRepairOrders    Boolean              @default(true)
  hasDiagnostics     Boolean              @default(false)
  hasFleetManagement Boolean              @default(false)
  hasHrManagement    Boolean              @default(true)
  hasCrm             Boolean              @default(true)
  hasPartsSourcing   Boolean              @default(false)
  hasReports         Boolean              @default(true)
  hasSms             Boolean              @default(false)
  hasWhatsapp        Boolean              @default(false)
  hasEmail           Boolean              @default(true)
  isActive           Boolean              @default(true)
  createdAt          DateTime             @default(now())
  updatedAt          DateTime             @updatedAt
  subscriptions      TenantSubscription[]

  @@map("subscription_plans")
}

model Tenant {
  id                   String               @id @default(cuid())
  status               TenantStatus         @default(PENDING_VERIFICATION)
  ownerName            String
  email                String               @unique
  phone                String
  password             String
  isEmailVerified      Boolean              @default(false)
  emailOtp             String?
  emailOtpExpiry       DateTime?
  garageName           String?
  garageAddress        String?
  city                 String?
  country              String?              @default("UAE")
  numberOfBranches     Int?                 @default(1)
  serviceTypes         ServiceType[]
  garagePhone          String?
  garageEmail          String?
  garageLogoUrl        String?
  trnNumber            String?
  companyBillingName   String?
  billingAddress       String?
  tradeLicenseFrontUrl String?
  tradeLicenseBackUrl  String?
  ownerIdFrontUrl      String?
  ownerIdBackUrl       String?
  vatCertificateUrl    String?
  rejectionReason      String?
  verifiedById         String?
  verifiedAt           DateTime?
  createdAt            DateTime             @default(now())
  updatedAt            DateTime             @updatedAt
  staff                Staff[]
  subscriptions        TenantSubscription[]
  verifiedBy           SuperAdmin?          @relation("VerifiedBy", fields: [verifiedById], references: [id])

  @@map("tenants")
}

model Staff {
  id                     String    @id @default(cuid())
  tenantId               String
  name                   String
  email                  String    @unique
  password               String
  role                   StaffRole @default(STAFF)
  phone                  String?
  address                String?
  skills                 String[]
  avatar                 String?
  isActive               Boolean   @default(true)
  canAccessDashboard     Boolean   @default(false)
  canAccessRepairOrders  Boolean   @default(false)
  canAccessDiagnostics   Boolean   @default(false)
  canAccessInventory     Boolean   @default(false)
  canAccessPartsSourcing Boolean   @default(false)
  canAccessFleet         Boolean   @default(false)
  canAccessHr            Boolean   @default(false)
  canAccessCustomers     Boolean   @default(false)
  canAccessServices      Boolean   @default(false)
  canAccessReports       Boolean   @default(false)
  canAccessBilling       Boolean   @default(false)
  canAccessSettings      Boolean   @default(false)
  idCardFrontUrl         String?
  idCardBackUrl          String?
  contractUrl            String?
  otherDocUrl            String?
  createdAt              DateTime  @default(now())
  updatedAt              DateTime  @updatedAt
  tenant                 Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@map("tenant_staff")
}

model TenantSubscription {
  id                String           @id @default(cuid())
  tenantId          String
  planId            String
  interval          PlanInterval     @default(MONTHLY)
  amount            Decimal          @db.Decimal(10, 2)
  status            PaymentStatus    @default(PENDING)
  isActive          Boolean          @default(false)
  razorpayOrderId   String?          @unique
  razorpayPaymentId String?          @unique
  razorpaySignature String?
  startDate         DateTime?
  endDate           DateTime?
  refundedAt        DateTime?
  refundAmount      Decimal?         @db.Decimal(10, 2)
  refundReason      String?
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt
  plan              SubscriptionPlan @relation(fields: [planId], references: [id])
  tenant            Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@map("tenant_subscriptions")
}

model Banner {
  id        String       @id @default(cuid())
  title     String?
  imageUrl  String
  linkUrl   String?
  target    BannerTarget @default(TENANT)
  isActive  Boolean      @default(true)
  priority  Int          @default(0)
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  @@map("banners")
}

model CmsContent {
  id        String       @id @default(cuid())
  type      CmsType
  target    BannerTarget @default(USER)
  isActive  Boolean      @default(true)
  priority  Int          @default(0)
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt
  title     Json
  content   Json

  @@map("cms_contents")
}

enum PlanType {
  BASIC
  PRO
  ENTERPRISE
}

enum PlanInterval {
  MONTHLY
  YEARLY
}

enum TenantStatus {
  PENDING_VERIFICATION
  ACTIVE
  REJECTED
  RESUBMITTED
  SUSPENDED
  BLOCKED
}

enum PaymentStatus {
  PENDING
  CAPTURED
  FAILED
  REFUNDED
}

enum ServiceType {
  REPAIR
  PAINT
  ELECTRICAL
  FULL_SERVICE
  TYRE_WHEEL
  AC_SERVICE
  BODY_WORK
  INSPECTION
  PERIODIC_MAINTENANCE
}

enum SuperAdminRole {
  SUPER_ADMIN
  SUPPORT_MANAGER
  BILLING_ADMIN
  TECHNICAL_ADMIN
}

enum StaffRole {
  TENANT_ADMIN
  MANAGER
  RECEPTIONIST
  MECHANIC
  STAFF
}

enum BannerTarget {
  TENANT
  USER
}

enum CmsType {
  FAQ
  PRIVACY_POLICY
  TERMS_CONDITIONS
}
